# ═══════════════════════════════════════════════════════════════════
# Nelatalli Organics — Admin Dashboard
# Environment Configuration
# ═══════════════════════════════════════════════════════════════════
# IMPORTANT: Do NOT commit the .env file. Only commit .env.example
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════════════

# Backend API URL (Required)
# Local Development: http://localhost:8000 or http://127.0.0.1:8000
# Production: https://api.nelatalli.com (replace with your production URL)
# This URL is used by the Vite proxy to route /api calls to the backend
VITE_API_URL=http://localhost:8000

# Admin API Base Path (Optional)
# Local Development: /api/admin (uses proxy from VITE_API_URL)
# Production: Leave empty to use proxy, or set to absolute URL
# Default: /api/admin
# VITE_API_BASE=https://api.nelatalli.com/api/admin

# Google Gemini API Key (Optional - for AI chatbot assistant)
# Get your free API key from: https://ai.google.dev/
# Leave empty to disable AI chatbot in admin panel
VITE_GEMINI_API_KEY=your-gemini-api-key-here

# Application Configuration (Optional)
VITE_APP_NAME=Nelatalli Organics Admin
VITE_ADMIN_PORT=3000
