# ═══════════════════════════════════════════════════════════════════
# Nelatalli Organics — Frontend (Customer Portal)
# Environment Configuration
# ═══════════════════════════════════════════════════════════════════
# IMPORTANT: Do NOT commit the .env file. Only commit .env.example
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════════════

# Backend API URL (Required)
# Local Development: http://localhost:8000
# Production: https://api.nelatalli.com (replace with your production URL)
VITE_API_URL=http://localhost:8000

# Google Gemini API Key (Optional - for AI chatbot/features)
# Get your free API key from: https://ai.google.dev/
# Leave empty to disable AI features
VITE_GEMINI_API_KEY=your-gemini-api-key-here

# Application Configuration (Optional)
VITE_APP_NAME=Nelatalli Organics
VITE_ENABLE_AI_FEATURES=true
VITE_ENABLE_PAYMENT_GATEWAY=true
